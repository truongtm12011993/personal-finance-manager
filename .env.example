# Local PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/finance_db?schema=public"

# Online PostgreSQL example. Replace user, password, host, and database.
# Most managed PostgreSQL providers require sslmode=require.
# DATABASE_URL="postgresql://user:password@host:5432/database?schema=public&sslmode=require"

# Auth.js / Google Login
# Generate AUTH_SECRET with: npx auth secret
AUTH_SECRET="replace-with-a-random-secret"
AUTH_GOOGLE_ID="replace-with-google-oauth-client-id"
AUTH_GOOGLE_SECRET="replace-with-google-oauth-client-secret"
